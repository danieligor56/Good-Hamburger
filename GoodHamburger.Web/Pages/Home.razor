@page "/"
@using GoodHamburger.Web.Models
@inject HttpClient Http

<PageTitle>Good Hamburger - Pedidos</PageTitle>

<div class="container mt-4">
    <div class="header-section text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">🍔 Good Hamburger</h1>
        <p class="lead text-muted">Monte seu pedido e aproveite nossos descontos progressivos!</p>
    </div>

    <div class="row g-4">
        <!-- Cardápio -->
        <div class="col-md-7">
            <h3 class="mb-4">📋 Cardápio</h3>
            @if (menuItems == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p>Carregando cardápio...</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    @foreach (var item in menuItems)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm hover-card">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5 class="card-title mb-0">@item.Name</h5>
                                        <small class="text-muted">@item.TypeFood</small>
                                        <div class="h5 text-success mt-2">@item.Price.ToString("C2")</div>
                                    </div>
                                    <button class="btn btn-outline-primary btn-sm rounded-pill" @onclick="() => AddToCart(item)">
                                        ➕ Adicionar
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Resumo do Pedido -->
        <div class="col-md-5">
            <div class="card border-primary shadow-lg sticky-top" style="top: 20px;">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0">🛒 Seu Pedido</h4>
                </div>
                <div class="card-body">
                    @if (!cartItems.Any())
                    {
                        <p class="text-center text-muted py-4">Seu carrinho está vazio.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var item in cartItems)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <strong>@item.Name</strong>
                                        <div class="text-muted small">@item.TypeFood</div>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <span class="me-3">@item.Price.ToString("C2")</span>
                                        <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => RemoveFromCart(item)">
                                            <i class="bi bi-trash"></i> ❌
                                        </button>
                                    </div>
                                </li>
                            }
                        </ul>

                        <div class="summary-details bg-light p-3 rounded">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal</span>
                                <span>@subtotal.ToString("C2")</span>
                            </div>
                            
                            @if (discountAmount > 0)
                            {
                                <div class="d-flex justify-content-between mb-2 text-success fw-bold">
                                    <div class="small">Desconto (@discountDescription)</div>
                                    <span>- @discountAmount.ToString("C2")</span>
                                </div>
                            }

                            <hr />
                            <div class="d-flex justify-content-between h4 fw-bold">
                                <span>Total</span>
                                <span>@total.ToString("C2")</span>
                            </div>
                        </div>

                        <button class="btn btn-primary w-100 mt-4 py-3 fw-bold rounded-pill" 
                                @onclick="FinalizeOrder" disabled="@isSubmitting">
                            @if(isSubmitting) {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Confirmar Pedido
                        </button>
                    }
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert mt-3 @(isError ? "alert-danger" : "alert-success")">
                    @statusMessage
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-card:hover {
        transform: translateY(-3px);
        transition: transform 0.2s ease;
        border-color: #0d6efd;
    }
    .header-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 3rem 1rem;
        border-radius: 20px;
    }
</style>

@code {
    private List<Food>? menuItems;
    private List<Food> cartItems = new();
    private decimal subtotal = 0;
    private decimal discountAmount = 0;
    private decimal total = 0;
    private string discountDescription = "";
    private bool isSubmitting = false;
    private string statusMessage = "";
    private bool isError = false;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            menuItems = await Http.GetFromJsonAsync<List<Food>>("api/menu");
        }
        catch (Exception ex)
        {
            statusMessage = "Erro ao carregar cardápio: " + ex.Message;
            isError = true;
        }
    }

    private void AddToCart(Food item)
    {
        // Limpar mensagens
        statusMessage = "";

        // Regra do desafio: Apenas 1 de cada tipo
        if (cartItems.Any(i => i.TypeFood == item.TypeFood))
        {
            statusMessage = $"Você já adicionou um {item.TypeFood.ToString().ToLower()}. Cada pedido permite apenas um de cada tipo.";
            isError = true;
            return;
        }

        cartItems.Add(item);
        CalculateTotals();
    }

    private void RemoveFromCart(Food item)
    {
        cartItems.Remove(item);
        CalculateTotals();
    }

    private void CalculateTotals()
    {
        subtotal = cartItems.Sum(i => i.Price);
        
        bool hasSandwich = cartItems.Any(i => i.TypeFood == FoodType.SANDUICHE);
        bool hasSide = cartItems.Any(i => i.TypeFood == FoodType.ACOMPANHAMENTO);
        bool hasDrink = cartItems.Any(i => i.TypeFood == FoodType.BEBIDA);

        decimal discountPercent = 0;
        discountDescription = "";

        if (hasSandwich && hasSide && hasDrink) {
            discountPercent = 0.20m;
            discountDescription = "20%";
        }
        else if (hasSandwich && hasDrink) {
            discountPercent = 0.15m;
            discountDescription = "15%";
        }
        else if (hasSandwich && hasSide) {
            discountPercent = 0.10m;
            discountDescription = "10%";
        }

        discountAmount = subtotal * discountPercent;
        total = subtotal - discountAmount;
    }

    private async Task FinalizeOrder()
    {
        isSubmitting = true;
        statusMessage = "";
        isError = false;

        try
        {
            var request = new OrderRequestDto { FoodIds = cartItems.Select(i => i.Id).ToList() };
            var response = await Http.PostAsJsonAsync("api/order", request);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "✅ Pedido realizado com sucesso! Bom apetite!";
                cartItems.Clear();
                CalculateTotals();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                statusMessage = "❌ Erro: " + (error?.Message ?? "Erro desconhecido.");
                isError = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = "❌ Erro ao enviar pedido: " + ex.Message;
            isError = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class ErrorResponse { public string Message { get; set; } = ""; }
}
